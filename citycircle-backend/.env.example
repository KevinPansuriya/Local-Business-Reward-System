PORT=4000
JWT_SECRET=replace_with_strong_secret

# Optional override for admin notification recipients (comma-separated).
# If not set, backend uses emails from admins table.
ADMIN_EMAILS=

# SMTP (Gmail example: use App Password, not Gmail account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
ADMIN_FROM_EMAIL=your_gmail_address@gmail.com

# Optional app URL used in outbound store outreach emails
APP_URL=http://localhost:5173

# Store outreach SMS toggle (0 = disabled, 1 = enabled)
# Keep 0 for now if store phone verification is not ready.
STORE_NOTIFY_SMS_ENABLED=0

# Cooldown to prevent duplicate outreach sends for same store name
STORE_NOTIFY_COOLDOWN_HOURS=24

# Store subscription defaults (no payment gateway yet)
STORE_SUBSCRIPTION_TRIAL_DAYS=14

# Direct promo from store to joined members (in-app always, SMS optional)
STORE_DIRECT_PROMO_SMS_ENABLED=0
